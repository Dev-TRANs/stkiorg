---
import { parse } from "node-html-parser";
type Props = {
  siteName: string,
  domain: string,
};

const { siteName, domain }: Props = Astro.props;

const pageResponse = await fetch(`https://${domain}/`).catch((error) => {
  console.error(`Error fetching ${domain}:`, error);
  return new Response("Error fetching page", { status: 500 });
});
const pageText = await pageResponse.text();

const root = parse(pageText);
const description = root.querySelector('meta[name="description"]')?.getAttribute("content");
---
<div class="border border-gray-200 rounded-lg shadow-sm">
    <a class="p-5 block" href={`https://${domain}/`}>
        <h5 class="text-md font-semibold tracking-tight text-gray-900">{siteName}</h5>
        <p class="font-light text-gray-700 underline">{domain}</p>
        {description && <p class="mt-3 text-sm line-clamp-3">{description}</p>}
    </a>
</div>
